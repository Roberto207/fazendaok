# ============================================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE - PLATAFORMA FAZENDAOK
# ============================================================================
#
# Este arquivo contém todas as variáveis de ambiente necessárias para
# executar a Plataforma FazendaOk. Copie este arquivo para .env e preencha
# com os valores reais.
#
# IMPORTANTE: Nunca commite o arquivo .env no repositório!
#
# Requisitos atendidos: 16.1, 16.2, 16.3, 16.4, 16.5, 16.6, 16.7, 16.8, 16.9, 16.10
# ============================================================================

# ============================================================================
# BANCO DE DADOS POSTGRESQL + POSTGIS
# ============================================================================
# URL de conexão com o banco de dados PostgreSQL com extensão PostGIS
# Formato: postgresql+asyncpg://usuario:senha@host:porta/nome_banco
# Requisito: 16.2
DATABASE_URL=postgresql+asyncpg://fazendaok:fazendaok@localhost:5432/fazendaok

# ============================================================================
# REDIS (Cache e Broker do Celery)
# ============================================================================
# URL de conexão com o servidor Redis
# Usado para cache de diagnósticos e como message broker do Celery
# Formato: redis://host:porta/database_number
# Requisito: 16.3
REDIS_URL=redis://localhost:6379/0 #isso aqui é instalado via doccker 
# docker run -d \
# --name redis \
# -p 6379:6379 \
# redis

# ============================================================================
# API INFOSIMPLES (Acesso ao SICAR)
# ============================================================================
# Token de autenticação para a API da Infosimples
# Obtenha em: https://www.infosimples.com/
# OBRIGATÓRIO para buscar dados de propriedades do CAR
# Requisito: 16.4
INFOSIMPLES_TOKEN=seu_token_infosimples_aqui

# ============================================================================
# API ANTHROPIC CLAUDE (Geração de Explicações)
# ============================================================================
# Chave de API da Anthropic para acesso ao Claude AI
# Obtenha em: https://console.anthropic.com/
# OBRIGATÓRIO para gerar explicações em linguagem natural
# Formato: sk-ant-...
# Requisito: 16.5
ANTHROPIC_API_KEY=sk-ant-seu_token_anthropic_aqui

# ============================================================================
# API GOOGLE MAPS (Mapas e Geocodificação)
# ============================================================================
# Chave de API do Google Maps
# Obtenha em: https://console.cloud.google.com/
# OBRIGATÓRIO para busca de endereços e exibição de mapas
# Formato: AIza...
# Requisito: 16.6
GOOGLE_MAPS_API_KEY=AIza_sua_chave_google_maps_aqui

# ============================================================================
# ARMAZENAMENTO S3 (Fotos das Propriedades)
# ============================================================================
# Nome do bucket S3 (ou compatível) para armazenar fotos
# Requisito: 16.7
AWS_BUCKET_NAME=fazendaok-photos

# Access Key ID para autenticação no S3
# Requisito: 16.7
AWS_ACCESS_KEY_ID=sua_access_key_id_aqui

# Secret Access Key para autenticação no S3
# Requisito: 16.7
AWS_SECRET_ACCESS_KEY=sua_secret_access_key_aqui

# URL do endpoint S3 (opcional)
# Para AWS S3 padrão: https://s3.amazonaws.com
# Para MinIO local: http://localhost:9000
# Para outros serviços compatíveis: especifique a URL completa
# Deixe em branco para usar AWS S3 padrão
# Requisito: 16.7
AWS_ENDPOINT_URL=https://s3.amazonaws.com

# ============================================================================
# CAMINHOS DOS SHAPEFILES (Dados de Desmatamento)
# ============================================================================
# Caminho completo para o shapefile do PRODES Cerrado
# Usado pelo script de ETL para carregar dados históricos de desmatamento
# Exemplo: /data/prodes_cerrado.shp
# Requisito: 16.8
PRODES_SHAPEFILE_PATH=/data/prodes_cerrado.shp

# Caminho completo para o shapefile do DETER Cerrado
# Usado pelo script de ETL para carregar alertas de desmatamento em tempo real
# Exemplo: /data/deter_cerrado.shp
# Requisito: 16.8
DETER_SHAPEFILE_PATH=/data/deter_cerrado.shp

# ============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ============================================================================
# Tamanho máximo permitido para upload de fotos (em megabytes)
# Padrão: 10
# Requisito: 16.9
MAX_FOTO_SIZE_MB=10

# Número máximo de fotos permitidas em um único upload
# Padrão: 20
# Requisito: 16.9
MAX_FOTOS_POR_UPLOAD=20

# Nível de log da aplicação
# Valores possíveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Padrão: INFO
LOG_LEVEL=INFO

# Limite de requisições por hora por endereço IP
# Usado para prevenir abuso da API
# Padrão: 100
RATE_LIMIT_PER_HOUR=100

# ============================================================================
# CACHE
# ============================================================================
# Tempo de vida (TTL) do cache de diagnósticos no Redis (em segundos)
# Padrão: 21600 (6 horas)
DIAGNOSTIC_CACHE_TTL_SECONDS=21600

# ============================================================================
# UPLOAD
# ============================================================================
# Diretório temporário para armazenar uploads antes do processamento
# Padrão: /tmp/fazendaok/uploads
UPLOAD_TEMP_DIR=/tmp/fazendaok/uploads
